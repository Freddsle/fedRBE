# Classification evaluation: temporary output folders and generated config files
**/classification_evaluation_output_*/
evaluation_data/**/config_forest.yaml

# anything with tmp in the name is meant to be temporary
**/tmp*

# Allow specific files to be used in git lfs
## Allow all federated corrected data
!evaluation_data/**/after/individual_results/*/full_corrected_data.csv
!evaluation_data/**/after/individual_results/*/only_batch_corrected_data.csv
!evaluation_data/quartet_multiomics/after/*/individual_results/*/full_corrected_data.csv
!evaluation_data/quartet_multiomics/after/*/individual_results/*/only_batch_corrected_data.csv
!evaluation_data/**/after/individual_results/*/report.txt

## Also the centrally corrected data
!evaluation_data/**/after/intensities_R_corrected.tsv
!evaluation_data/**/after/*/intensities_R_corrected.tsv

## Allow the simulated rotation before data
## This data is too big but is added to git lfs
## Other data in simulated_rotation is prohibided so we need to
## specifically add it here
!evaluation_data/simulated_rotation/*/before/lab*/design.tsv
!evaluation_data/simulated_rotation/*/before/lab*/intensities.tsv


